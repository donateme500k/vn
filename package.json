// WEATHER
// ════════════════════════════════════════════════════════════
const WCO_MAP={0:'☀️',1:'🌤️',2:'⛅',3:'☁️',45:'🌫️',48:'🌫️',51:'🌦️',53:'🌧️',55:'🌧️',61:'🌦️',63:'🌧️',65:'🌧️',71:'🌨️',73:'❄️',75:'❄️',80:'🌦️',81:'🌧️',82:'⛈️',85:'🌨️',86:'❄️',95:'⛈️',96:'⛈️',99:'⛈️'};
const WCO_TXT={0:'Trời quang',1:'Ít mây',2:'Mây từng phần',3:'Trời nhiều mây',45:'Sương mù',48:'Sương mù đóng băng',51:'Mưa phùn nhẹ',53:'Mưa phùn',55:'Mưa phùn nặng',61:'Mưa nhỏ',63:'Mưa vừa',65:'Mưa to',71:'Tuyết nhỏ',73:'Tuyết vừa',75:'Tuyết to',80:'Mưa rào nhẹ',81:'Mưa rào',82:'Mưa rào mạnh',85:'Mưa tuyết nhẹ',86:'Mưa tuyết',95:'Dông bão',96:'Dông kèm mưa đá',99:'Dông mưa đá nặng'};
const DAYS=['CN','T2','T3','T4','T5','T6','T7'];

async function loadWeatherPage(){
  const w=$('weatherWrap');if(!w)return;
  w.innerHTML='<div class="loading"><i class="fa fa-spinner"></i>Đang tải...</div>';
  const d=await apiFetch('weather','&lat=10.7769&lon=106.7009');
  if(!d){w.innerHTML='<div class="err-box">Không thể tải dữ liệu thời tiết</div>';return;}
  renderWeather(d,'TP.Hồ Chí Minh',w);
}
function renderWeather(d,city,container){
  const cw=d.current;
  const wc=cw.weather_code;
  const ico=WCO_MAP[wc]||'🌡️';
  const desc=WCO_TXT[wc]||'—';
  const temp=Math.round(cw.temperature_2m);
  const feel=Math.round(cw.apparent_temperature||temp);
  const hum=cw.relative_humidity_2m||0;
  const wind=Math.round(cw.wind_speed_10m||0);
  const uv=Math.round(cw.uv_index||0);
  const precip=(cw.precipitation||0).toFixed(1);

  setE('h-temp',temp+'°C');
  setE('h-wdesc',ico+' '+desc);

  // Hourly forecast
  const now=new Date().getHours();
  const hIdx=d.hourly?.time?.findIndex(t=>new Date(t).getHours()===now)||0;
  const hourlyHTML=d.hourly?.time?.slice(hIdx,hIdx+12).map((t,i)=>{
    const hr=new Date(t).getHours();
    const temp2=Math.round(d.hourly.temperature_2m[hIdx+i]);
    const wcH=d.hourly.weather_code[hIdx+i];
    const pop=d.hourly.precipitation_probability[hIdx+i]||0;
    const isNow=i===0;
    return `<div class="hc${isNow?' now':''}"><div class="ht">${isNow?'Hiện tại':String(hr).padStart(2,'0')+'h'}</div><div class="hi">${WCO_MAP[wcH]||'🌡️'}</div><div class="hp">${temp2}°</div><div class="hrn">${pop>0?pop+'%':''}</div></div>`;
  }).join('')||'';

  // 7-day forecast
  const dailyHTML=d.daily?.time?.map((t,i)=>{
    const wcd=d.daily.weather_code[i];
    const tmax=Math.round(d.daily.temperature_2m_max[i]);
    const tmin=Math.round(d.daily.temperature_2m_min[i]);
    const uvi=Math.round(d.daily.uv_index_max[i]||0);
    const precD=(d.daily.precipitation_sum[i]||0).toFixed(1);
    const dow=new Date(t).getDay();
    const lbl=i===0?'Hôm nay':i===1?'Ngày mai':DAYS[dow];
    return `<div class="dr"><div class="dday">${lbl}</div><div class="dico">${WCO_MAP[wcd]||'🌡️'}</div><div class="ddesc">${WCO_TXT[wcd]||''} · UV:${uvi} · ${precD}mm</div><div class="drange"><span class="dhi">${tmax}°</span> <span class="dlo">${tmin}°</span></div></div>`;
  }).join('')||'';

  container.innerHTML=`
    <div class="wcard">
      <div style="display:flex;justify-content:space-between;align-items:flex-start">
        <div><div style="font-size:11px;color:var(--t2);margin-bottom:4px;letter-spacing:.5px;text-transform:uppercase">${city}</div>
        <div class="wt">${temp}°</div>
        <div class="wdesc">${desc}</div>
        <div style="font-size:10px;color:var(--t2);margin-top:3px">Cảm giác như ${feel}°C</div></div>
        <div class="wico">${ico}</div>
      </div>
      <div class="wgrid">
        <div class="ws"><div class="wsv">${hum}%</div><div class="wsl">Độ ẩm</div></div>
        <div class="ws"><div class="wsv">${wind} km/h</div><div class="wsl">Gió</div></div>
        <div class="ws"><div class="wsv">UV ${uv}</div><div class="wsl">Chỉ số UV</div></div>
        <div class="ws"><div class="wsv">${precip}mm</div><div class="wsl">Lượng mưa</div></div>
        <div class="ws"><div class="wsv">${d.daily?.sunrise?.[0]?.slice(11,16)||'—'}</div><div class="wsl">🌅 Mặt trời mọc</div></div>
        <div class="ws"><div class="wsv">${d.daily?.sunset?.[0]?.slice(11,16)||'—'}</div><div class="wsl">🌇 Mặt trời lặn</div></div>
      </div>
    </div>
    <div class="slbl"><i class="fa-solid fa-clock"></i>Dự Báo Theo Giờ</div>
    <div class="hscr">${hourlyHTML}</div>
    <div class="slbl"><i class="fa-solid fa-calendar-week"></i>Dự Báo 7 Ngày</div>
    <div class="c" style="padding:14px 14px 4px">${dailyHTML}</div>
    <div style="text-align:center;font-size:9px;color:var(--t3);padding:8px 0">Nguồn: Open-Meteo · Cập nhật: ${now2()}</div>
  `;
}

