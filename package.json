<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>VN PULSE · Thị Trường Thời Gian Thực</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
:root{
  --bg:#03050c;
  --s1:#070d1a;
  --s2:#0b1220;
  --s3:#101828;
  --s4:#162035;
  --border:rgba(255,255,255,0.055);
  --border-b:rgba(0,168,255,0.13);
  --a:#00a8ff;
  --a2:#0077cc;
  --a3:#40c8ff;
  --vn:#ff3b4e;
  --vn2:#ff6b78;
  --g:#00c97a;
  --g2:#38e09a;
  --r:#ff3b4e;
  --r2:#ff6b78;
  --amber:#ffb020;
  --amber2:#ffd060;
  --text:#dde6f0;
  --t2:#5a7090;
  --t3:#1d2e42;
  --ff1:'DM Sans',sans-serif;
  --ff2:'Syne',sans-serif;
  --ffm:'DM Mono',monospace;
  --grad-a:linear-gradient(135deg,#00a8ff,#0066cc);
  --grad-r:linear-gradient(135deg,#ff3b4e,#cc1a2a);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{font-size:14px;}
body{background:var(--bg);color:var(--text);font-family:var(--ff1);min-height:100vh;overflow-x:hidden;padding-bottom:76px;}

/* Grid noise bg */
body::before{
  content:'';position:fixed;inset:0;
  background-image:
    linear-gradient(rgba(0,168,255,0.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,168,255,0.025) 1px,transparent 1px);
  background-size:40px 40px;
  pointer-events:none;z-index:0;
}
body::after{
  content:'';position:fixed;top:0;left:0;right:0;height:400px;
  background:radial-gradient(ellipse 70% 350px at 50% -60px,rgba(0,168,255,0.06),transparent);
  pointer-events:none;z-index:0;
}

/* ── TICKER ───────────────────────────────────────────────── */
.tkw{overflow:hidden;height:30px;display:flex;align-items:center;background:rgba(0,168,255,0.04);border-bottom:1px solid var(--border-b);position:relative;z-index:2;}
.tkw::before,.tkw::after{content:'';position:absolute;top:0;bottom:0;width:60px;z-index:2;}
.tkw::before{left:0;background:linear-gradient(90deg,var(--bg),transparent);}
.tkw::after{right:0;background:linear-gradient(-90deg,var(--bg),transparent);}
.tktrack{display:flex;white-space:nowrap;font-family:var(--ffm);font-size:10px;animation:tkScroll 90s linear infinite;}
.tki{padding:0 20px;display:flex;gap:6px;align-items:center;color:var(--t2);}
.tki .s{color:var(--a);font-weight:500;}
.tki .u{color:var(--g2);}
.tki .d{color:var(--r2);}
.tki .sep{color:var(--t3);}
@keyframes tkScroll{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}

/* ── HEADER ───────────────────────────────────────────────── */
.hdr{position:sticky;top:0;z-index:100;background:rgba(3,5,12,0.96);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border);}
.hdr-top{display:flex;align-items:center;justify-content:space-between;padding:9px 14px;}
.logo{display:flex;align-items:center;gap:9px;}
.logo-mark{width:32px;height:32px;border-radius:8px;background:var(--grad-r);display:flex;align-items:center;justify-content:center;font-size:16px;box-shadow:0 0 18px rgba(255,59,78,0.45),0 0 40px rgba(255,59,78,0.15);}
.logo-text{line-height:1;}
.logo-name{font-family:var(--ff2);font-size:20px;font-weight:800;letter-spacing:2px;background:linear-gradient(90deg,#fff,#a0c8e8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.logo-sub{font-family:var(--ffm);font-size:8px;color:var(--t2);letter-spacing:2.5px;margin-top:1px;text-transform:uppercase;}
.hdr-right{display:flex;gap:8px;align-items:center;}
.live-pill{display:flex;align-items:center;gap:5px;padding:3px 9px;border-radius:20px;font-family:var(--ffm);font-size:9px;font-weight:500;letter-spacing:.4px;color:var(--g2);background:rgba(0,201,122,0.08);border:1px solid rgba(0,201,122,0.2);}
.live-dot{width:5px;height:5px;border-radius:50%;background:var(--g2);box-shadow:0 0 5px var(--g2);animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.4;transform:scale(.8);}}
.clk-display{font-family:var(--ffm);font-size:11px;color:var(--a);letter-spacing:.5px;}

/* ── TAB BAR ──────────────────────────────────────────────── */
.tabs{display:flex;overflow-x:auto;scrollbar-width:none;border-top:1px solid var(--border);}
.tabs::-webkit-scrollbar{display:none;}
.tb{flex:1;min-width:48px;display:flex;flex-direction:column;align-items:center;gap:2px;padding:7px 3px 6px;font-family:var(--ff2);font-size:8px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:var(--t2);background:none;border:none;border-bottom:2px solid transparent;cursor:pointer;transition:color .2s,border-color .2s;}
.tb i{font-size:12px;}
.tb.on{color:var(--a);border-bottom-color:var(--a);}

/* ── PAGE ─────────────────────────────────────────────────── */
.pg{display:none;padding:12px 12px 4px;animation:pgIn .2s ease;position:relative;z-index:1;}
.pg.on{display:block;}
@keyframes pgIn{from{opacity:0;transform:translateY(5px);}to{opacity:1;transform:translateY(0);}}

/* ── SECTION LABEL ────────────────────────────────────────── */
.slbl{display:flex;align-items:center;gap:8px;margin:16px 0 8px;font-family:var(--ff2);font-size:9px;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:2px;}
.slbl i{color:var(--a);font-size:10px;}
.slbl::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--border-b),transparent);}

/* ── CARD ─────────────────────────────────────────────────── */
.c{background:var(--s1);border:1px solid var(--border);border-radius:14px;padding:14px;margin-bottom:10px;position:relative;overflow:hidden;}
.c::before{content:'';position:absolute;inset:0;background:linear-gradient(140deg,rgba(255,255,255,0.02),transparent 55%);pointer-events:none;}
.c-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.c-hl{display:flex;align-items:center;gap:6px;font-family:var(--ff2);font-size:10px;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:1.2px;}
.c-hl i{color:var(--a);}
.src-tag{font-family:var(--ffm);font-size:8.5px;color:var(--t3);display:flex;align-items:center;gap:4px;}
.src-tag .dot{width:4px;height:4px;border-radius:50%;background:var(--g2);box-shadow:0 0 4px var(--g2);}

/* ── STAT GRID ────────────────────────────────────────────── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px;}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-bottom:10px;}
.g4{display:grid;grid-template-columns:repeat(2,1fr);gap:7px;margin-bottom:10px;}

/* ── STAT CARD ────────────────────────────────────────────── */
.sc{background:var(--s1);border:1px solid var(--border);border-radius:14px;padding:12px 11px;cursor:pointer;transition:border-color .2s,transform .12s;overflow:hidden;position:relative;}
.sc:active{transform:scale(.97);}
.sc:hover{border-color:rgba(0,168,255,0.22);}
.sc-ico{position:absolute;right:10px;top:9px;font-size:18px;opacity:.22;}
.sc-lbl{font-family:var(--ff2);font-size:8.5px;font-weight:700;color:var(--t2);letter-spacing:1px;text-transform:uppercase;margin-bottom:5px;}
.sc-val{font-family:var(--ffm);font-size:17px;font-weight:400;line-height:1.1;letter-spacing:-.3px;margin-bottom:4px;}
.sc-ch{font-family:var(--ffm);font-size:9.5px;font-weight:500;display:inline-flex;align-items:center;gap:2px;padding:2px 6px;border-radius:4px;}
.sc-ch.u{color:var(--g2);background:rgba(0,201,122,0.1);}
.sc-ch.d{color:var(--r2);background:rgba(255,59,78,0.1);}
.sc-sub{font-size:8.5px;color:var(--t3);margin-top:5px;}
.sc.accent{border-color:rgba(0,168,255,0.18);background:linear-gradient(135deg,rgba(0,168,255,0.05),var(--s1));}

/* ── ROW ──────────────────────────────────────────────────── */
.row{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border);}
.row:last-child{border-bottom:none;}
.rl{display:flex;align-items:center;gap:8px;}
.rr{text-align:right;}
.rname{font-size:12.5px;font-weight:500;}
.rsub{font-size:9px;color:var(--t2);margin-top:1px;}
.rval{font-family:var(--ffm);font-size:12px;}
.rch{font-family:var(--ffm);font-size:10px;font-weight:500;}
.rch.u{color:var(--g2);}
.rch.d{color:var(--r2);}
.rch.nc{color:var(--t2);}

/* ── CRYPTO ROW ───────────────────────────────────────────── */
.cr{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--border);transition:background .15s;}
.cr:last-child{border-bottom:none;}
.cr:hover{background:rgba(255,255,255,0.015);margin:0 -14px;padding:9px 14px;}
.cr-ico{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;font-family:var(--ffm);font-weight:700;}
.cr-name{font-size:12.5px;font-weight:600;}
.cr-sym{font-size:9px;color:var(--t2);}
.cr-val{font-family:var(--ffm);font-size:12.5px;}
.cr-ch{font-family:var(--ffm);font-size:9.5px;font-weight:500;}
.cr-ch.u{color:var(--g2);}
.cr-ch.d{color:var(--r2);}
.pbar{height:2px;background:rgba(255,255,255,0.05);border-radius:1px;margin-top:3px;}
.pfill{height:100%;border-radius:1px;transition:width .5s ease;}

/* ── COMMODITY ────────────────────────────────────────────── */
.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px;}
.cc{background:var(--s1);border:1px solid var(--border);border-radius:13px;padding:12px 11px;cursor:pointer;transition:border-color .2s,transform .12s;position:relative;overflow:hidden;}
.cc:active{transform:scale(.97);}
.cc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;}
.cc-lbl{font-family:var(--ff2);font-size:9.5px;font-weight:700;color:var(--t2);letter-spacing:.4px;}
.cc-sym{font-size:8px;color:var(--t3);margin-top:1px;}
.cc-ico{font-size:20px;}
.cc-price{font-family:var(--ffm);font-size:16px;margin-bottom:3px;letter-spacing:-.2px;}
.cc-ch{font-family:var(--ffm);font-size:10px;font-weight:500;}
.cc-ch.u{color:var(--g2);}
.cc-ch.d{color:var(--r2);}
.cc-unit{font-size:8px;color:var(--t3);margin-top:3px;}

/* ── HEATMAP ──────────────────────────────────────────────── */
.hmap{display:grid;grid-template-columns:repeat(4,1fr);gap:5px;margin-bottom:10px;}
.hmc{border-radius:9px;padding:8px 5px;text-align:center;cursor:pointer;transition:transform .12s,opacity .15s;}
.hmc:active{transform:scale(.95);}
.hmn{font-family:var(--ff2);font-size:8.5px;font-weight:700;color:rgba(255,255,255,.85);margin-bottom:2px;}
.hmv{font-family:var(--ffm);font-size:10px;}

/* ── WORLD CLOCKS ─────────────────────────────────────────── */
.clocks{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;}
.clk-cell{background:var(--s2);border:1px solid var(--border);border-radius:10px;padding:9px 6px;text-align:center;transition:border-color .3s;}
.clk-cell.mopen{border-color:rgba(0,201,122,0.28);background:rgba(0,201,122,0.04);}
.cty{font-family:var(--ff2);font-size:8px;color:var(--t2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:2px;}
.ctm{font-family:var(--ffm);font-size:15px;font-weight:300;}
.cdt{font-size:8px;color:var(--t3);margin-top:1px;}
.cdot{display:inline-block;width:5px;height:5px;border-radius:50%;background:var(--t3);margin-bottom:2px;}
.cdot.open{background:var(--g2);box-shadow:0 0 5px var(--g2);}

/* ── WEATHER ──────────────────────────────────────────────── */
.wcard{background:linear-gradient(145deg,#040c1a,#06101e);border:1px solid rgba(0,168,255,0.1);border-radius:14px;padding:16px;margin-bottom:10px;position:relative;overflow:hidden;}
.wcard::before{content:'';position:absolute;top:-40px;right:-40px;width:180px;height:180px;background:radial-gradient(circle,rgba(0,168,255,0.055),transparent 70%);}
.wt{font-family:var(--ff2);font-size:56px;font-weight:800;line-height:1;letter-spacing:-1px;}
.wdesc{font-size:11.5px;color:var(--t2);margin-top:3px;}
.wico{font-size:48px;line-height:1;}
.wgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-top:12px;}
.ws{background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:9px;padding:8px;text-align:center;}
.wsv{font-family:var(--ffm);font-size:14px;}
.wsl{font-size:8.5px;color:var(--t2);margin-top:2px;}
.hscr{display:flex;gap:6px;overflow-x:auto;padding:2px 0 4px;scrollbar-width:none;margin-bottom:10px;}
.hscr::-webkit-scrollbar{display:none;}
.hc{background:var(--s1);border:1px solid var(--border);border-radius:9px;padding:8px 10px;min-width:52px;text-align:center;flex-shrink:0;}
.hc.now{border-color:var(--a);background:rgba(0,168,255,0.05);}
.ht{font-size:9px;color:var(--t2);margin-bottom:4px;}
.hi{font-size:18px;margin-bottom:3px;}
.hp{font-family:var(--ffm);font-size:12px;}
.hrn{font-size:8px;color:var(--a);margin-top:2px;}
.dr{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border);}
.dr:last-child{border-bottom:none;}
.dday{font-size:12px;font-weight:500;width:60px;}
.dico{font-size:20px;width:26px;text-align:center;}
.ddesc{font-size:10px;color:var(--t2);flex:1;padding:0 8px;}
.drange{font-family:var(--ffm);font-size:12px;}
.dhi{color:var(--text);}
.dlo{color:var(--t2);}

/* ── FEAR & GREED ─────────────────────────────────────────── */
.fg-wrap{padding:4px 0 16px;}
.fg-num{font-family:var(--ff2);font-size:52px;font-weight:800;line-height:1;letter-spacing:-2px;}
.fg-lbl{font-size:12px;color:var(--t2);margin-top:4px;margin-bottom:14px;}
.fg-bar{height:8px;border-radius:4px;background:linear-gradient(to right,#ff3b4e,#ffb020,#ffd060,#00c97a,#00a8ff);margin:10px 0 6px;position:relative;}
.fg-needle{position:absolute;top:-6px;width:20px;height:20px;border-radius:50%;background:#fff;transform:translateX(-50%);box-shadow:0 2px 12px rgba(0,0,0,.7);transition:left .9s cubic-bezier(.34,1.56,.64,1);}
.fg-labels{display:flex;justify-content:space-between;font-family:var(--ffm);font-size:8px;color:var(--t3);}
.fg-hist{display:flex;gap:4px;margin-top:12px;}
.fg-hbar{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;}
.fg-hv{font-family:var(--ffm);font-size:9px;}
.fg-hb{width:100%;border-radius:3px;transition:height .4s;}
.fg-hd{font-size:8px;color:var(--t3);}

/* ── NEWS ─────────────────────────────────────────────────── */
.ni{display:flex;gap:11px;padding:11px 0;border-bottom:1px solid var(--border);cursor:pointer;transition:background .15s;}
.ni:last-child{border-bottom:none;}
.ni:active{background:rgba(255,255,255,0.02);margin:0 -14px;padding:11px 14px;}
.ni-ico{font-size:22px;flex-shrink:0;}
.ntag{display:inline-block;padding:2px 7px;border-radius:4px;font-family:var(--ff2);font-size:8.5px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px;}
.te{background:rgba(0,201,122,0.1);color:var(--g2);}
.tt{background:rgba(0,168,255,0.1);color:var(--a);}
.tg{background:rgba(255,59,78,0.1);color:var(--r2);}
.tm{background:rgba(255,176,32,0.1);color:var(--amber2);}
.ntitle{font-size:12.5px;line-height:1.5;}
.nmeta{font-size:9px;color:var(--t3);margin-top:3px;}

/* ── VN TABLE ─────────────────────────────────────────────── */
.vntab{width:100%;border-collapse:collapse;}
.vntab th{font-family:var(--ff2);font-size:8.5px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--t2);padding:6px 7px;border-bottom:1px solid var(--border);text-align:right;}
.vntab th:first-child{text-align:left;}
.vntab td{font-family:var(--ffm);font-size:11px;padding:7px 7px;border-bottom:1px solid var(--border);text-align:right;}
.vntab td:first-child{text-align:left;font-family:var(--ff1);font-size:12px;font-weight:600;}
.vntab tr:last-child td{border-bottom:none;}
.vntab .u{color:var(--g2);}
.vntab .d{color:var(--r2);}
.vntab .nc{color:var(--t2);}
.vntab tr:hover td{background:rgba(255,255,255,0.015);}

/* ── BADGES ───────────────────────────────────────────────── */
.b-open{font-size:8px;font-weight:700;padding:1px 5px;border-radius:4px;background:rgba(0,201,122,0.1);color:var(--g2);border:1px solid rgba(0,201,122,0.2);}
.b-close{font-size:8px;padding:1px 5px;border-radius:4px;background:rgba(45,55,72,0.15);color:var(--t2);border:1px solid var(--border);}

/* ── CHARTS ───────────────────────────────────────────────── */
.chbox{position:relative;height:165px;}
.chleg{display:flex;gap:14px;font-size:9px;color:var(--t2);justify-content:center;margin-top:6px;}
.chleg span{display:flex;align-items:center;gap:4px;}

/* ── BUTTONS ──────────────────────────────────────────────── */
.rbtn{display:inline-flex;align-items:center;gap:5px;font-size:9.5px;color:var(--a);background:rgba(0,168,255,0.06);border:1px solid rgba(0,168,255,0.18);border-radius:20px;padding:5px 12px;cursor:pointer;font-weight:500;font-family:var(--ff1);transition:all .15s;}
.rbtn:hover{background:rgba(0,168,255,0.12);}
.rbtn.spinning i{animation:spin 1s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.pbtn{padding:10px 20px;border-radius:10px;border:none;background:var(--grad-r);color:#fff;font-size:13px;font-weight:600;cursor:pointer;font-family:var(--ff2);letter-spacing:.5px;transition:all .15s;}
.pbtn:hover{opacity:.88;transform:translateY(-1px);}
.pbtn:active{transform:translateY(0);}
.pbtn2{padding:9px 16px;border-radius:10px;border:1px solid rgba(255,255,255,.1);background:transparent;color:var(--text);font-size:12px;font-weight:500;cursor:pointer;font-family:var(--ff1);transition:all .15s;}
.pbtn2:hover{background:rgba(255,255,255,.06);}

/* ── TOOLKIT ──────────────────────────────────────────────── */
.tk-tabs{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:14px;}
.tk-tab{padding:7px 13px;border-radius:9px;border:1px solid rgba(255,255,255,.08);background:transparent;color:var(--t2);font-size:12px;font-weight:500;cursor:pointer;white-space:nowrap;transition:all .15s;font-family:var(--ff1);}
.tk-tab:hover{background:rgba(255,255,255,.05);color:var(--text);}
.tk-tab.act{background:rgba(255,59,78,.15);color:var(--vn2);border-color:rgba(255,59,78,.35);}
.tk-panel{display:none;}
.tk-panel.on{display:block;}
.ifield{display:flex;flex-direction:column;gap:5px;margin-bottom:12px;}
.ifield label{font-size:10.5px;color:var(--t2);font-weight:600;letter-spacing:.3px;text-transform:uppercase;}
.iinput{padding:10px 13px;border-radius:9px;border:1px solid rgba(255,255,255,.08);background:rgba(0,0,0,.4);color:var(--text);font-size:13px;width:100%;font-family:var(--ff1);transition:border-color .15s;outline:none;}
.iinput:focus{border-color:rgba(255,59,78,.45);}
select.iinput option{background:#0b1220;}
.fr{display:flex;align-items:flex-start;justify-content:space-between;padding:9px 0;border-bottom:1px solid rgba(255,255,255,.05);gap:10px;}
.fr:last-child{border-bottom:none;}
.fl{font-size:10px;color:var(--t2);min-width:100px;flex-shrink:0;padding-top:3px;text-transform:uppercase;letter-spacing:.4px;}
.fv{font-size:13px;color:var(--text);font-weight:500;flex:1;word-break:break-all;line-height:1.5;}
.cpbtn{padding:4px 10px;border-radius:6px;border:1px solid rgba(255,255,255,.1);background:transparent;color:var(--t2);font-size:11px;cursor:pointer;white-space:nowrap;flex-shrink:0;font-family:var(--ff1);transition:all .12s;}
.cpbtn:hover{background:rgba(255,255,255,.06);color:var(--text);}
.cpbtn.ok{background:rgba(0,201,122,.12);color:var(--g2);border-color:rgba(0,201,122,.28);}
.codeout{padding:11px 13px;background:rgba(0,0,0,.5);border-radius:9px;font-size:12px;color:var(--text);word-break:break-all;font-family:var(--ffm);line-height:1.7;border:1px solid rgba(255,255,255,.06);}
.bbsel{padding:9px 8px;border-radius:9px;border:1px solid rgba(255,255,255,.07);background:#080d1a;color:var(--text);font-size:11px;font-weight:500;cursor:pointer;text-align:center;transition:all .12s;font-family:var(--ff1);line-height:1.4;}
.bbsel:hover{border-color:rgba(255,59,78,.3);}
.bbsel.sel{background:rgba(255,59,78,.15);color:var(--vn2);border-color:rgba(255,59,78,.4);}
.st{font-family:var(--ff2);font-size:14px;font-weight:700;color:var(--text);margin-bottom:12px;display:flex;align-items:center;gap:8px;}

/* ── QR & BANK ────────────────────────────────────────────── */
.qrbox{display:flex;flex-direction:column;align-items:center;gap:14px;padding:22px;background:rgba(0,0,0,.4);border-radius:12px;}
.qrbox canvas,.qrbox img{border-radius:8px;}

/* ── BANK SELECTOR ────────────────────────────────────────── */
.bank-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:12px;}
.bank-btn{padding:8px 5px;border-radius:9px;border:1px solid rgba(255,255,255,.07);background:#080d1a;color:var(--t2);font-size:10px;font-weight:500;cursor:pointer;text-align:center;transition:all .12s;font-family:var(--ff1);}
.bank-btn:hover{border-color:rgba(0,168,255,.3);color:var(--text);}
.bank-btn.sel{background:rgba(0,168,255,.15);color:var(--a);border-color:rgba(0,168,255,.4);}
.bank-logo{font-size:15px;margin-bottom:2px;}

/* ── MODAL ────────────────────────────────────────────────── */
.moverlay{position:fixed;inset:0;background:rgba(0,0,0,.82);z-index:200;display:none;align-items:flex-end;backdrop-filter:blur(6px);}
.moverlay.on{display:flex;}
.mbox{background:var(--s2);border-top:1px solid var(--border-b);border-radius:20px 20px 0 0;padding:18px 16px max(18px,env(safe-area-inset-bottom));width:100%;max-height:85vh;overflow-y:auto;animation:mUp .3s cubic-bezier(.34,1.56,.64,1);}
@keyframes mUp{from{transform:translateY(100%);}to{transform:translateY(0);}}
.mhandle{width:36px;height:4px;background:var(--s3);border-radius:2px;margin:0 auto 16px;}
.mtitle{font-family:var(--ff2);font-size:22px;font-weight:800;letter-spacing:.5px;}
.mprice{font-family:var(--ffm);font-size:30px;font-weight:300;margin:10px 0 4px;letter-spacing:-1px;}
.mstats{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin:14px 0;}
.ms{background:rgba(255,255,255,0.03);border:1px solid var(--border);border-radius:9px;padding:10px;text-align:center;}
.msv{font-family:var(--ffm);font-size:13px;}
.msl{font-size:9px;color:var(--t2);margin-top:3px;}
.mchart{height:140px;margin-bottom:14px;}
.mclose{width:100%;padding:13px;background:var(--grad-a);color:#000;border-radius:11px;border:none;font-weight:700;font-size:14px;cursor:pointer;font-family:var(--ff2);letter-spacing:.5px;}

/* ── LOADING / ERROR ──────────────────────────────────────── */
.loading{display:flex;align-items:center;justify-content:center;gap:8px;padding:24px;font-size:12px;color:var(--t2);}
.loading i{font-size:14px;color:var(--a);animation:spin 1s linear infinite;}
.err-box{background:rgba(255,59,78,0.06);border:1px solid rgba(255,59,78,0.18);border-radius:10px;padding:13px;font-size:11px;color:var(--r2);text-align:center;}

/* ── TOAST ────────────────────────────────────────────────── */
.toast{position:fixed;top:80px;left:50%;transform:translateX(-50%) translateY(-12px);background:rgba(0,168,255,0.12);border:1px solid rgba(0,168,255,0.28);backdrop-filter:blur(12px);border-radius:20px;padding:8px 16px;font-family:var(--ffm);font-size:11px;color:var(--a);z-index:300;opacity:0;transition:all .28s;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* ── BOTTOM NAV ───────────────────────────────────────────── */
.nav{position:fixed;bottom:0;left:0;right:0;z-index:100;background:rgba(3,5,12,.97);backdrop-filter:blur(20px);border-top:1px solid var(--border);display:flex;padding:4px 0 max(4px,env(safe-area-inset-bottom));}
.nb{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:6px 4px;font-family:var(--ff2);font-size:7.5px;font-weight:700;letter-spacing:.3px;text-transform:uppercase;color:var(--t2);background:none;border:none;cursor:pointer;transition:color .2s;}
.nb i{font-size:15px;transition:transform .2s,filter .2s;}
.nb.on{color:var(--a);}
.nb.on i{transform:scale(1.15);filter:drop-shadow(0 0 4px var(--a));}

/* ── SCROLLBAR ────────────────────────────────────────────── */
::-webkit-scrollbar{width:3px;height:3px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--s3);border-radius:2px;}

/* ── MACRO STAT ───────────────────────────────────────────── */
.macro-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:10px;}
.macro-item{background:var(--s2);border:1px solid var(--border);border-radius:11px;padding:10px 12px;}
.macro-val{font-family:var(--ffm);font-size:18px;font-weight:400;margin:3px 0;color:var(--a);}
.macro-lbl{font-size:9px;color:var(--t2);font-weight:600;letter-spacing:.3px;text-transform:uppercase;}
.macro-src{font-size:8px;color:var(--t3);margin-top:2px;}

/* ── ECON CALENDAR ────────────────────────────────────────── */
.ecal-item{padding:9px 0;border-bottom:1px solid var(--border);}
.ecal-item:last-child{border-bottom:none;}
.ecal-hd{display:flex;align-items:center;gap:7px;margin-bottom:4px;}
.ecal-imp{display:flex;gap:2px;}
.ecal-imp span{width:5px;height:5px;border-radius:50%;background:var(--t3);}
.ecal-imp.h3 span{background:var(--r2);}
.ecal-imp.h2 span:nth-child(-n+2){background:var(--amber);}
.ecal-imp.h1 span:nth-child(1){background:var(--g2);}
.ecal-ev{font-size:12px;font-weight:500;}
.ecal-meta{display:flex;gap:10px;font-family:var(--ffm);font-size:10px;}
.ecal-dt{color:var(--t2);}
.ecal-act{color:var(--text);}
.ecal-fore{color:var(--t2);}
.ecal-prev{color:var(--t3);}

@media(max-width:375px){.sc-val{font-size:15px;}.wt{font-size:48px;}.fg-num{font-size:44px;}}
@media(max-width:340px){.nb{font-size:7px;}.nb i{font-size:13px;}}
</style>
</head>
