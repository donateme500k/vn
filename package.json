function renderForex(){
  const el=$('forexWrap');if(!el)return;
  if(!fxRates.rates){el.innerHTML='<div class="loading"><i class="fa fa-spinner"></i></div>';return;}
  const r=fxRates.rates;
  const pairs=[
    {f:'🇺🇸→🇻🇳',p:'USD/VND',v:Math.round(r.VND).toLocaleString('vi-VN')},
    {f:'🇪🇺→🇻🇳',p:'EUR/VND',v:Math.round(r.VND/r.EUR).toLocaleString('vi-VN')},
    {f:'🇯🇵→🇻🇳',p:'JPY/VND',v:(r.VND/r.JPY).toFixed(1)},
    {f:'🇨🇳→🇻🇳',p:'CNY/VND',v:Math.round(r.VND/r.CNY).toLocaleString('vi-VN')},
    {f:'🇬🇧→🇻🇳',p:'GBP/VND',v:Math.round(r.VND/r.GBP).toLocaleString('vi-VN')},
    {f:'🇸🇬→🇻🇳',p:'SGD/VND',v:Math.round(r.VND/r.SGD).toLocaleString('vi-VN')},
    {f:'🇺🇸→🇯🇵',p:'USD/JPY',v:r.JPY?.toFixed(3)},
    {f:'🇺🇸→🇨🇳',p:'USD/CNY',v:r.CNY?.toFixed(4)},
    {f:'🇪🇺→🇺🇸',p:'EUR/USD',v:(1/r.EUR)?.toFixed(5)},
    {f:'🇬🇧→🇺🇸',p:'GBP/USD',v:(1/r.GBP)?.toFixed(5)},
    {f:'🇺🇸→🇰🇷',p:'USD/KRW',v:Math.round(r.KRW)?.toLocaleString()},
    {f:'🇺🇸→🇦🇺',p:'USD/AUD',v:r.AUD?.toFixed(4)},
    {f:'🇺🇸→🇨🇭',p:'USD/CHF',v:r.CHF?.toFixed(4)},
    {f:'🇺🇸→🇹🇭',p:'USD/THB',v:r.THB?.toFixed(3)},
    {f:'🇺🇸→🇲🇾',p:'USD/MYR',v:r.MYR?.toFixed(4)},
    {f:'🇺🇸→🇵🇭',p:'USD/PHP',v:r.PHP?.toFixed(3)},
    {f:'🇺🇸→🇮🇩',p:'USD/IDR',v:Math.round(r.IDR)?.toLocaleString()},
    {f:'🇺🇸→🇮🇳',p:'USD/INR',v:r.INR?.toFixed(3)},
  ];
  el.innerHTML=pairs.map(p=>`<div class="row"><div class="rl"><span style="font-size:16px">${p.f}</span><div><div class="rname">${p.p}</div><div class="rsub">ExchangeRate-API</div></div></div><div class="rr"><div class="rval">${p.v||'—'}</div></div></div>`).join('');
}
function renderGlobalStats(){
  const el=$('globalStats');if(!el)return;
  const BIRTHS=4.43,DEATHS=1.83,CO2=424.74;
  const EPOCH=Date.UTC(2025,0,1),POP=8091735079;
  function live(){
    const s=(Date.now()-EPOCH)/1000;
    const b=Math.floor(s*BIRTHS),de=Math.floor(s*DEATHS);
    const pop=POP+b-de;
    const mo=new Date().getMonth(),seasonal=Math.sin((mo-1)/12*2*Math.PI)*3.2;
    const co2=(CO2+seasonal).toFixed(2);
    const fL=Math.floor(s*4700000/31536000);
    return{b,de,pop,co2,fL};
  }
  function render(){
    const{b,de,pop,co2,fL}=live();
    el.innerHTML=`
