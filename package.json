function mkGrad(ctx,color,alpha=0.15){const g=ctx.createLinearGradient(0,0,0,200);g.addColorStop(0,color.replace(')',`,${alpha})`).replace('rgb','rgba'));g.addColorStop(1,'rgba(0,0,0,0)');return g;}
function simPrices(base,n=24,vol=0.015){const p=[base];for(let i=1;i<n;i++)p.push(p[p.length-1]*(1+(Math.random()-0.5)*vol*2));return p;}

function drawHomeChart(){
  const el=$('chartHome');if(!el)return;
  const btcBase=cryptoData.coins?.bitcoin?.usd||85000;
  const ethBase=cryptoData.coins?.ethereum?.usd||1800;
  const labels=Array.from({length:24},(_,i)=>{const h=(new Date().getHours()-23+i+24)%24;return h+':00';});
  const btcP=simPrices(btcBase,24,0.008);
  const ethP=simPrices(ethBase,24,0.01);
  if(chartHome)chartHome.destroy();
  const ctx=el.getContext('2d');
  chartHome=new Chart(ctx,{type:'line',data:{labels,datasets:[
    {label:'BTC',data:btcP,borderColor:'#00a8ff',borderWidth:1.5,backgroundColor:mkGrad(ctx,'rgb(0,168,255)'),fill:true,tension:.4,pointRadius:0,yAxisID:'y'},
    {label:'ETH',data:ethP,borderColor:'#ff3b4e',borderWidth:1.5,backgroundColor:mkGrad(ctx,'rgb(255,59,78)'),fill:true,tension:.4,pointRadius:0,yAxisID:'y1'},
  ]},options:{...CHART_OPT,scales:{...CHART_OPT.scales,y:{...CHART_OPT.scales.y,type:'linear',display:true,position:'left'},y1:{...CHART_OPT.scales.y,type:'linear',display:true,position:'right',grid:{drawOnChartArea:false}}}}});
}
function drawBTCChart(d){
  const el=$('chartBTC');if(!el)return;
  const base=d?.bitcoin?.usd||85000;
  const labels=Array.from({length:7},(_,i)=>{const d=new Date();d.setDate(d.getDate()-6+i);return d.toLocaleDateString('vi-VN',{day:'2-digit',month:'2-digit'});});
  const prices=simPrices(base,7,0.02);
  if(chartBTC)chartBTC.destroy();
  const ctx=el.getContext('2d');
  chartBTC=new Chart(ctx,{type:'line',data:{labels,datasets:[{label:'BTC',data:prices,borderColor:'#f7931a',borderWidth:2,backgroundColor:mkGrad(ctx,'rgb(247,147,26)',0.12),fill:true,tension:.4,pointRadius:3,pointBackgroundColor:'#f7931a'}]},options:CHART_OPT});
}
function drawETHChart(d){
  const el=$('chartETH');if(!el)return;
  const base=d?.ethereum?.usd||1800;
  const labels=Array.from({length:7},(_,i)=>{const d=new Date();d.setDate(d.getDate()-6+i);return d.toLocaleDateString('vi-VN',{day:'2-digit',month:'2-digit'});});
  const prices=simPrices(base,7,0.025);
  if(chartETH)chartETH.destroy();
  const ctx=el.getContext('2d');
  chartETH=new Chart(ctx,{type:'line',data:{labels,datasets:[{label:'ETH',data:prices,borderColor:'#627eea',borderWidth:2,backgroundColor:mkGrad(ctx,'rgb(98,126,234)',0.12),fill:true,tension:.4,pointRadius:3,pointBackgroundColor:'#627eea'}]},options:CHART_OPT});
}
function drawMktChart(idx){
  const el=$('chartMkt');if(!el)return;
  if(!idx||!Object.keys(idx).length)return;
  const keys=['sp500','nasdaq','dow','nikkei','hangseng','dax'];
  const labels=keys.map(k=>({sp500:'S&P',nasdaq:'NASDAQ',dow:'DOW',nikkei:'N225',hangseng:'HSI',dax:'DAX'}[k]||k.toUpperCase()));
  const changes=keys.map(k=>+(idx[k]?.change||0).toFixed(2));
  const colors=changes.map(c=>c>=0?'rgba(0,201,122,0.7)':'rgba(255,59,78,0.7)');
  if(chartMkt)chartMkt.destroy();
  const ctx=el.getContext('2d');
  chartMkt=new Chart(ctx,{type:'bar',data:{labels,datasets:[{data:changes,backgroundColor:colors,borderColor:colors.map(c=>c.replace('0.7','1')),borderWidth:1,borderRadius:6}]},options:{...CHART_OPT,plugins:{...CHART_OPT.plugins,tooltip:{callbacks:{label:ctx=>(ctx.raw>=0?'▲':'')+ctx.raw+'%'}}}}});
}

