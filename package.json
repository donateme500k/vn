function openModal(id){
  const m=COMM_META[id]||{n:id,ico:'📊',unit:'USD',color:'#5a7090'};
  const item=commData[id];
  $('moverlay').classList.add('on');
  $('mContent').innerHTML=`
    <div class="mtitle">${m.ico} ${m.n}</div>
    <div class="mprice" style="color:${m.color}">
      ${item?.price?'$'+item.price.toLocaleString('en-US',{maximumFractionDigits:2}):'—'}
      <span class="${(item?.change||0)>=0?'sc-ch u':'sc-ch d'}" style="font-size:14px;margin-left:8px">${item?.change?(((item.change>=0?'▲':'▼')+Math.abs(item.change).toFixed(2)+'%')):'—'}</span>
    </div>
    <div class="mstats">
      <div class="ms"><div class="msv">${item?.high?'$'+item.high.toLocaleString('en-US',{maximumFractionDigits:2}):'—'}</div><div class="msl">Cao nhất ngày</div></div>
      <div class="ms"><div class="msv">${item?.low?'$'+item.low.toLocaleString('en-US',{maximumFractionDigits:2}):'—'}</div><div class="msl">Thấp nhất ngày</div></div>
      <div class="ms"><div class="msv">${item?.prev?'$'+item.prev.toLocaleString('en-US',{maximumFractionDigits:2}):'—'}</div><div class="msl">Phiên trước</div></div>
      <div class="ms"><div class="msv">${m.unit}</div><div class="msl">Đơn vị</div></div>
    </div>
    <div class="mchart"><canvas id="mChart"></canvas></div>
    <button class="mclose" onclick="closeModal()">Đóng</button>`;
  setTimeout(()=>{
    const ec=$('mChart');if(!ec)return;
    const prices=simPrices(item?.price||100,30,0.01);
    const labels=Array.from({length:30},(_,i)=>{const d=new Date();d.setDate(d.getDate()-29+i);return d.getDate()+'/'+( d.getMonth()+1);});
    new Chart(ec.getContext('2d'),{type:'line',data:{labels,datasets:[{data:prices,borderColor:m.color,borderWidth:1.5,backgroundColor:mkGrad(ec.getContext('2d'),'rgb('+hexToRgb(m.color)+')'),fill:true,tension:.4,pointRadius:0}]},options:CHART_OPT});
  },100);
}
function openCommModal(id){openModal(id);}
function closeModal(){$('moverlay').classList.remove('on');}
function hexToRgb(hex){try{const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);return `${r},${g},${b}`;}catch{return '99,99,99';}}

