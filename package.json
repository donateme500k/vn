const HO_NAM=['Nguyễn','Trần','Lê','Phạm','Hoàng','Huỳnh','Vũ','Võ','Phan','Trương','Bùi','Đặng','Đỗ','Ngô','Hồ','Dương','Đinh'];
const HO_NU=HO_NAM;
const TEN_NAM=['Anh','Bình','Cường','Dũng','Đức','Hải','Hùng','Khoa','Lâm','Long','Minh','Nam','Nghĩa','Phong','Phúc','Quân','Quang','Sơn','Thanh','Thắng','Toàn','Trung','Tú','Tuấn','Việt','Hưng','Khôi','Nhân'];
const TEN_NU=['An','Anh','Bích','Duyên','Giang','Hà','Hạnh','Hiền','Hoa','Hồng','Huệ','Hương','Lan','Liên','Linh','Mai','Ngọc','Nhung','Phương','Quỳnh','Thanh','Thu','Thủy','Trang','Trinh','Uyên','Vân','Yến','Châu','Diễm'];
const TEN_DEM_NAM=['Văn','Hữu','Đức','Ngọc','Minh','Quốc','Thanh','Trọng','Xuân','Công','Bá'];
const TEN_DEM_NU=['Thị','Ngọc','Mỹ','Hoàng','Thu','Ánh','Thanh','Bảo','Kim','Phương'];
const TINH_NORTH=['Hà Nội','Hải Phòng','Nam Định','Thái Bình','Ninh Bình','Hà Nam','Hưng Yên','Hải Dương','Bắc Ninh','Vĩnh Phúc','Phú Thọ','Tuyên Quang','Yên Bái','Lào Cai','Sơn La','Điện Biên','Lai Châu','Hà Giang','Cao Bằng','Bắc Kạn','Thái Nguyên','Lạng Sơn','Bắc Giang','Quảng Ninh'];
const TINH_CENTRAL=['Đà Nẵng','Huế','Quảng Nam','Quảng Ngãi','Bình Định','Phú Yên','Khánh Hòa','Ninh Thuận','Bình Thuận','Đắk Lắk','Gia Lai','Kon Tum','Lâm Đồng','Đắk Nông','Nghệ An','Hà Tĩnh','Quảng Bình','Quảng Trị','Thanh Hóa'];
const TINH_SOUTH=['TP.HCM','Bình Dương','Đồng Nai','Bà Rịa-Vũng Tàu','Long An','Tiền Giang','Bến Tre','Vĩnh Long','Cần Thơ','An Giang','Kiên Giang','Cà Mau','Bạc Liêu','Sóc Trăng','Hậu Giang','Đồng Tháp','Trà Vinh','Bình Phước','Tây Ninh'];
const TINH_ALL=[...TINH_NORTH,...TINH_CENTRAL,...TINH_SOUTH];

function genPerson(gender=null, region=null){
  const g=gender||( ri(0,1)?'Nam':'Nữ');
  const ho=HO_NAM[ri(0,HO_NAM.length-1)];
  const dem=(g==='Nam'?TEN_DEM_NAM:TEN_DEM_NU)[ri(0,(g==='Nam'?TEN_DEM_NAM:TEN_DEM_NU).length-1)];
  const ten=(g==='Nam'?TEN_NAM:TEN_NU)[ri(0,(g==='Nam'?TEN_NAM:TEN_NU).length-1)];
  const hoTen=ho+' '+dem+' '+ten;
  const year=ri(1970,2005),month=ri(1,12),day=ri(1,28);
  const ngaySinh=String(day).padStart(2,'0')+'/'+String(month).padStart(2,'0')+'/'+year;
  
  let tinhList=TINH_ALL;
  if(region==='north')tinhList=TINH_NORTH;
  else if(region==='central')tinhList=TINH_CENTRAL;
  else if(region==='south')tinhList=TINH_SOUTH;
  const tinh=tinhList[ri(0,tinhList.length-1)];
  
  const provCode={
    'Hà Nội':79,'TP.HCM':79,'Hải Phòng':31,'Đà Nẵng':43,'Cần Thơ':92,
    'Hà Nam':35,'Nam Định':36,'Thái Bình':34,'Ninh Bình':37,'Hưng Yên':33,
  }[tinh]||ri(11,99);
  const cccd=String(provCode).padStart(2,'0')+(g==='Nam'?ri(0,4):ri(5,9))+(year%100+'').padStart(2,'0')+ri(10000,99999)+''+ri(0,9);
  const sdt=['032','033','034','035','036','037','038','039','070','076','077','078','079','086','096','097','098','090','091','094','083','084','085','058','056'][ri(0,24)];
  const soDienThoai=sdt+ri(1000000,9999999);
  const email=ho.toLowerCase().replace(/[àáạảãăắặẳẵâấậẩẫđèéẹẻẽêếệểễìíịỉĩòóọỏõôốộổỗơớợởỡùúụủũưứựửữỳýỵỷỹ]/g,c=>'aaaaaaaaaaadeeeeeeeeeiiiiiooooooooooooouuuuuuuuuuyyyy'['àáạảãăắặẳẵâấậẩẫđèéẹẻẽêếệểễìíịỉĩòóọỏõôốộổỗơớợởỡùúụủũưứựửữỳýỵỷỹ'.indexOf(c)]||c)
    +ten.toLowerCase().replace(/[àáạảãăắặẳẵâấậẩẫđèéẹẻẽêếệểễìíịỉĩòóọỏõôốộổỗơớợởỡùúụủũưứựửữỳýỵỷỹ]/g,c=>'aaaaaaaaaaadeeeeeeeeeiiiiiooooooooooooouuuuuuuuuuyyyy'['àáạảãăắặẳẵâấậẩẫđèéẹẻẽêếệểễìíịỉĩòóọỏõôốộổỗơớợởỡùúụủũưứựửữỳýỵỷỹ'.indexOf(c)]||c)
    +ri(100,9999)
    +['@gmail.com','@yahoo.com','@outlook.com','@hotmail.com'][ri(0,3)];
  const queQuan=tinh;
  const duong=['Nguyễn Trãi','Lê Lợi','Trần Hưng Đạo','Đinh Tiên Hoàng','Lý Thường Kiệt','Nguyễn Huệ','Hùng Vương','Trần Phú','Phan Chu Trinh','Cách Mạng Tháng 8'][ri(0,9)];
  const diaChiThuongTru=ri(1,350)+' '+duong+', '+['Phường','Quận','Huyện'][ri(0,2)]+' '+ri(1,15)+', '+tinh;
  return{hoTen,gioiTinh:g,ngaySinh,cccd,soDienThoai,email,queQuan,diaChiThuongTru,danToc:'Kinh',tonGiao:'Không',tinhTrangHonNhan:ri(0,1)?'Độc thân':'Đã kết hôn'};
}

function gen(){
  const g=($('dc-gender')?.value||'random')==='random'?null:$('dc-gender').value;
  const r=$('dc-region')?.value==='all'?null:$('dc-region').value;
  const p=genPerson(g,r);
  const out=$('dc-out');if(!out)return;
  const fields=[
    ['Họ và tên',p.hoTen,'fn'],['Giới tính',p.gioiTinh,'gn'],['Ngày sinh',p.ngaySinh,'dob'],
    ['Số CCCD',p.cccd,'cccd'],['Số điện thoại',p.soDienThoai,'sdt'],['Email',p.email,'em'],
    ['Quê quán',p.queQuan,'qq'],['Địa chỉ thường trú',p.diaChiThuongTru,'dc'],
    ['Dân tộc',p.danToc,'dt2'],['Tôn giáo',p.tonGiao,'tg2'],['Hôn nhân',p.tinhTrangHonNhan,'hn'],
  ];
  out.innerHTML=`<button onclick="gen()" style="width:100%;margin-bottom:12px" class="pbtn2">↻ Tạo lại</button>`+fields.map(([lbl,val,id])=>`<div class="fr"><div class="fl">${lbl}</div><div class="fv" id="${id}">${escH(val)}</div><button class="cpbtn" onclick="cp('${id}',this)">Sao chép</button></div>`).join('');
}

// ════════════════════════════════════════════════════════════
// QR CODE
// ════════════════════════════════════════════════════════════
function genQR(){
  const txt=$('qr-text').value.trim();
  if(!txt){toast('⚠ Nhập nội dung trước');return;}
  const size=parseInt($('qr-size').value)||250;
  const bg=$('qr-bg').value||'#ffffff';
  const out=$('qr-out');
  out.innerHTML='<div class="qrbox"><div id="qrimg"></div></div>';
  try{
    new QRCode($('qrimg'),{text:txt,width:size,height:size,colorDark:'#000000',colorLight:bg,correctLevel:QRCode.CorrectLevel.M});
    setTimeout(()=>{
      const canvas=out.querySelector('canvas');
      if(canvas){
        const dl=document.createElement('a');dl.href=canvas.toDataURL();dl.download='qrcode.png';
        out.querySelector('.qrbox').insertAdjacentHTML('beforeend','<button class="pbtn2" onclick="this.previousElementSibling?.click?.()">⬇ Tải QR</button>');
        out.querySelector('.pbtn2').onclick=()=>{dl.click();};
      }
    },200);
  }catch(e){out.innerHTML='<div class="err-box">Lỗi tạo QR: '+e.message+'</div>';}
}

// ════════════════════════════════════════════════════════════
// VIETQR
// ════════════════════════════════════════════════════════════
function initBankGrid(){
  const el=$('bankGrid');if(!el||el.dataset.init)return;
  el.dataset.init='1';
  el.innerHTML=BANKS.map((b,i)=>`<div class="bank-btn" onclick="selectBank(${i},this)"><div class="bank-logo">${b.logo}</div><div>${b.short}</div></div>`).join('');
}
function selectBank(i,btn){
  selectedBank=BANKS[i];
  document.querySelectorAll('.bank-btn').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel');
}
function genVietQR(){
  if(!selectedBank){toast('⚠ Chọn ngân hàng trước');return;}
  const acct=$('bank-acct').value.trim();
  if(!acct){toast('⚠ Nhập số tài khoản');return;}
  const amt=$('bank-amt').value||0;
  const desc=encodeURIComponent($('bank-desc').value||'');
  const name=encodeURIComponent($('bank-name').value||'');
  // VietQR standard URL
  const qrContent=`https://img.vietqr.io/image/${selectedBank.bin}-${acct}-compact2.jpg?amount=${amt}&addInfo=${desc}&accountName=${name}`;
  const out=$('bank-out');
  out.innerHTML=`<div class="qrbox">
    <img src="https://img.vietqr.io/image/${selectedBank.bin}-${acct}-compact2.jpg?amount=${amt}&addInfo=${desc}&accountName=${name}" 
         style="max-width:280px;width:100%;border-radius:12px" 
         onerror="this.parentElement.innerHTML='<div class=\\'err-box\\'>Không thể tạo QR. Kiểm tra số tài khoản và thử lại.</div>'"
         alt="VietQR">
    <div style="text-align:center">
      <div style="font-size:12px;font-weight:600">${selectedBank.name}</div>
      <div style="font-family:var(--ffm);font-size:13px;color:var(--a);margin:3px 0">${acct}</div>
      ${amt>0?`<div style="font-size:12px;color:var(--g2)">${parseInt(amt).toLocaleString('vi-VN')} ₫</div>`:''}
      ${$('bank-desc').value?`<div style="font-size:11px;color:var(--t2)">${$('bank-desc').value}</div>`:''}
    </div>
    <a href="https://img.vietqr.io/image/${selectedBank.bin}-${acct}-compact2.jpg?amount=${amt}&addInfo=${desc}&accountName=${name}" download="vietqr.jpg" class="pbtn2" style="text-decoration:none;display:inline-block">⬇ Tải QR</a>
  </div>`;
}

// ════════════════════════════════════════════════════════════
// TOOLKIT TOOLS
// ════════════════════════════════════════════════════════════
function genPW(){
  const len=parseInt($('pw-len').value)||16;
  let chars='';
  if($('pw-lo').checked) chars+='abcdefghijklmnopqrstuvwxyz';
  if($('pw-up').checked) chars+='ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  if($('pw-num').checked) chars+='0123456789';
  if($('pw-sym').checked) chars+='!@#$%^&*()-_=+[]{}|;:,.<>?';
  if(!chars) chars='abcdefghijklmnopqrstuvwxyz0123456789';
  let pw='';for(let i=0;i<len;i++)pw+=chars[ri(0,chars.length-1)];
  const strength=len>=16&&/[A-Z]/.test(pw)&&/[0-9]/.test(pw)&&/[^a-zA-Z0-9]/.test(pw)?'💪 Rất mạnh':len>=12?'✅ Mạnh':len>=8?'⚠️ Trung bình':'❌ Yếu';
  const id='pw-'+Date.now();
  $('pw-out').innerHTML=`<div class="codeout" id="${id}" style="font-size:14px;letter-spacing:1.5px;word-break:break-all">${pw}</div><div style="display:flex;gap:8px;margin-top:8px;align-items:center"><button class="cpbtn" onclick="cp('${id}',this)">Sao chép</button><button class="pbtn2" style="font-size:11px;padding:5px 10px" onclick="genPW()">↻ Tạo lại</button><span style="font-size:11px;color:var(--t2)">${strength}</span></div>`;
}
function setUV(m,btn){uvMode=m;document.querySelectorAll('.bbsel').forEach(b=>b.classList.remove('sel'));btn.classList.add('sel');}
function uuidv4(){return'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g,c=>{const r=Math.random()*16|0;return(c==='x'?r:(r&0x3|0x8)).toString(16);});}
function nanoId(len=21){const c='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_';let s='';for(let i=0;i<len;i++)s+=c[ri(0,c.length-1)];return s;}
function genUUIDs(){
  const n=Math.min(50,Math.max(1,parseInt($('uuid-count').value)||5));
  const ids=[];
  for(let i=0;i<n;i++){if(uvMode==='v4')ids.push(uuidv4());else if(uvMode==='v1')ids.push(Date.now().toString(16).padStart(8,'0')+uuidv4().substring(8));else ids.push(nanoId());}
  const id='uuid-'+Date.now();
  $('uuid-out').innerHTML=`<div class="codeout" id="${id}" style="white-space:pre-line">${ids.join('\n')}</div><button class="cpbtn" onclick="cp('${id}',this)" style="margin-top:8px">Sao chép tất cả</button>`;
}
function b64enc(){try{const v=$('b64-in').value;const e=btoa(unescape(encodeURIComponent(v)));const id='b64e-'+Date.now();$('b64-out').innerHTML=`<div class="codeout" id="${id}">${e}</div><button class="cpbtn" onclick="cp('${id}',this)" style="margin-top:8px">Sao chép</button>`;}catch(e){$('b64-out').innerHTML='<p style="color:var(--r2);font-size:13px">Lỗi: '+e.message+'</p>';}}
function b64dec(){try{const v=$('b64-in').value;const d=decodeURIComponent(escape(atob(v)));const id='b64d-'+Date.now();$('b64-out').innerHTML=`<div class="codeout" id="${id}">${escH(d)}</div><button class="cpbtn" onclick="cp('${id}',this)" style="margin-top:8px">Sao chép</button>`;}catch(e){$('b64-out').innerHTML='<p style="color:var(--r2);font-size:13px">Lỗi: không phải Base64 hợp lệ</p>';}}
function fmtVND(){
  const v=$('vnd-num').value;if(!v){$('vnd-out').textContent='—';return;}
  const n=Number(v);
  $('vnd-out').innerHTML=`<strong style="font-size:15px">${n.toLocaleString('vi-VN')} ₫</strong><br><span style="font-size:11px;color:var(--t2)">${numToWords(n)} đồng</span>`;
}
function numToWords(n){
  if(n===0)return'Không';if(n<0)return'Âm '+numToWords(-n);
  const u=['','một','hai','ba','bốn','năm','sáu','bảy','tám','chín'];
  const t=['','mười','hai mươi','ba mươi','bốn mươi','năm mươi','sáu mươi','bảy mươi','tám mươi','chín mươi'];
  function h(n){if(n===0)return'';const H=Math.floor(n/100),T=Math.floor((n%100)/10),U=n%10;let r=H>0?u[H]+' trăm':'';if(T>0)r+=(r?' ':'')+t[T]+(U>0?' '+u[U]:'');else if(U>0)r+=(r?' lẻ ':'')+u[U];return r;}
  if(n>=1e9)return h(Math.floor(n/1e9))+' tỷ '+(n%1e9?numToWords(n%1e9):'');
  if(n>=1e6)return h(Math.floor(n/1e6))+' triệu '+(n%1e6?numToWords(n%1e6):'');
  if(n>=1e3)return h(Math.floor(n/1e3))+' nghìn '+(n%1e3?numToWords(n%1e3):'');
  return h(n);
}
function encURL(){
  const v=$('url-in').value;if(!v){$('url-out').innerHTML='';return;}
  const id1='ue-'+Date.now(),id2='ud-'+Date.now();
  $('url-out').innerHTML=`<div style="margin-top:10px"><div style="font-size:10px;color:var(--t2);margin-bottom:5px;text-transform:uppercase;letter-spacing:.4px">encodeURIComponent</div><div class="codeout" id="${id1}">${encodeURIComponent(v)}</div><button class="cpbtn" onclick="cp('${id1}',this)" style="margin-top:6px">Sao chép</button></div>`;
}
function hslToHex(h,s,l){s/=100;l/=100;const k=n=>(n+h/30)%12;const a=s*Math.min(l,1-l);const f=n=>l-a*Math.max(-1,Math.min(k(n)-3,Math.min(9-k(n),1)));return[f(0),f(8),f(4)].map(x=>Math.round(x*255).toString(16).padStart(2,'0')).join('');}
function genColor(){
  const colors=[];for(let i=0;i<6;i++){const h=ri(0,360),s=ri(45,90),l=ri(35,65);colors.push({hex:'#'+hslToHex(h,s,l)});}
  $('color-out').innerHTML=`<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px">${colors.map(c=>{const id='col-'+Math.random().toString(36).slice(2,6);return`<div style="border-radius:10px;overflow:hidden;border:1px solid var(--border)"><div style="height:55px;background:${c.hex}"></div><div style="padding:7px 9px;background:rgba(0,0,0,.5)"><div class="codeout" id="${id}" style="font-size:11px;padding:3px 5px">${c.hex}</div><button class="cpbtn" onclick="cp('${id}',this)" style="margin-top:5px;font-size:10px">Sao chép</button></div></div>`;}).join('')}</div>`;
}
function calcDays(){
  const f=$('date-from').value,t=$('date-to').value;
  if(!f||!t){toast('⚠ Chọn đủ hai ngày');return;}
  const d1=new Date(f),d2=new Date(t);
  const diff=Math.round((d2-d1)/(1000*60*60*24));
  const abs=Math.abs(diff);
  const weeks=Math.floor(abs/7),days2=abs%7;
  const months=Math.floor(abs/30);
  $('date-out').innerHTML=`<div class="codeout" style="font-size:14px"><strong style="color:var(--a)">${diff} ngày</strong><br><span style="font-size:11px;color:var(--t2)">${weeks} tuần ${days2} ngày · ~${months} tháng</span></div>`;
}
function calcInvest(){
  const p=parseFloat($('invest-init').value)||0;
  const r=parseFloat($('invest-rate').value)||0;
  const y=Math.min(50,parseInt($('invest-years').value)||1);
  if(!p||!r){toast('⚠ Nhập đầy đủ thông tin');return;}
  const final=p*Math.pow(1+r/100,y);
  const profit=final-p;
  const rows=Array.from({length:Math.min(y,10)},(_,i)=>{const yr=i+1;const v=p*Math.pow(1+r/100,yr);return`<tr><td>Năm ${yr}</td><td>${Math.round(v).toLocaleString('vi-VN')}</td><td style="color:var(--g2)">+${(v-p).toLocaleString('vi-VN',{maximumFractionDigits:0})}</td></tr>`;}).join('');
  $('invest-out').innerHTML=`<div class="codeout"><strong style="font-size:14px;color:var(--a)">${Math.round(final).toLocaleString('vi-VN')} ₫</strong><br><span style="color:var(--g2)">Lợi nhuận: +${Math.round(profit).toLocaleString('vi-VN')} ₫</span><br><span style="font-size:10px;color:var(--t2)">Lãi kép ${r}%/năm × ${y} năm</span></div><div style="overflow-x:auto;margin-top:10px"><table class="vntab"><thead><tr><th style="text-align:left">Năm</th><th>Tổng tiền</th><th>Lợi nhuận</th></tr></thead><tbody>${rows}</tbody></table></div>`;
}

// ════════════════════════════════════════════════════════════
// BATCH
// ════════════════════════════════════════════════════════════
let batchData=[];
function genBatch(){
  const n=Math.min(100,Math.max(1,parseInt($('bt-count').value)||10));
  const fg=$('bt-gender').value;
  batchData=[];
  for(let i=0;i<n;i++)batchData.push(genPerson(fg==='random'?null:fg));
  const rows=batchData.map((p,i)=>`<tr><td style="padding:7px 8px;font-size:11px;color:var(--t2)">${i+1}</td><td style="padding:7px 8px;font-size:12px;font-weight:500">${escH(p.hoTen)}</td><td style="padding:7px 8px;font-size:11px">${p.gioiTinh}</td><td style="padding:7px 8px;font-size:11px">${p.ngaySinh}</td><td style="padding:7px 8px;font-size:11px;font-family:monospace">${p.cccd}</td><td style="padding:7px 8px;font-size:11px">${p.soDienThoai}</td></tr>`).join('');
  $('batch-out').innerHTML=`<div class="c" style="overflow-x:auto;padding:0"><table class="vntab"><thead><tr><th>#</th><th style="text-align:left">Họ tên</th><th>GT</th><th>Ngày sinh</th><th>CCCD</th><th>SĐT</th></tr></thead><tbody>${rows}</tbody></table></div>`;
}
function copyBatch(){
  if(!batchData.length){toast('⚠ Tạo danh sách trước');return;}
  const hdr='Họ tên,Giới tính,Ngày sinh,CCCD,SĐT,Email,Quê quán,Địa chỉ';
  const rows=batchData.map(p=>`"${p.hoTen}","${p.gioiTinh}","${p.ngaySinh}","${p.cccd}","${p.soDienThoai}","${p.email}","${p.queQuan}","${p.diaChiThuongTru}"`).join('\n');
  navigator.clipboard.writeText(hdr+'\n'+rows).then(()=>toast('✓ Đã sao chép '+batchData.length+' dòng CSV'));
}
function copyBatchJSON(){
  if(!batchData.length){toast('⚠ Tạo danh sách trước');return;}
  navigator.clipboard.writeText(JSON.stringify(batchData,null,2)).then(()=>toast('✓ Đã sao chép JSON ('+batchData.length+' người)'));
}

// ════════════════════════════════════════════════════════════
// INIT
// ════════════════════════════════════════════════════════════
window.onload=async()=>{
  updateClock();setInterval(updateClock,1000);
  refreshClocks();setInterval(refreshClocks,5000);
  gen();// init dancu tab
  await loadHome();
  setInterval(loadHome,120000);
  setInterval(buildTicker,30000);
  setInterval(drawHomeChart,300000);
};
