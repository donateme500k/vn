  Object.keys(d).forEach(id=>{
    const c=d[id];const m=CMETA[id]||{n:id,sym:id.toUpperCase(),ico:'●',color:'#5a7090'};
    const ch=c.usd_24h_change||0;const cls=ch>=0?'u':'d';
    const pFmt=c.usd<0.0001?c.usd.toFixed(8):c.usd<0.01?c.usd.toFixed(6):c.usd<1?c.usd.toFixed(4):c.usd.toLocaleString('en-US',{maximumFractionDigits:2});
    const pct=Math.min(100,Math.abs(ch)*7);
    h+=`<div class="cr"><div class="cr-ico" style="background:${m.color}18;color:${m.color}">${m.ico}</div><div style="flex:1"><div class="cr-name">${m.n}</div><div class="cr-sym">${m.sym}${c.usd_market_cap?' · '+fmtB(c.usd_market_cap):''}</div><div class="pbar"><div class="pfill" style="width:${pct}%;background:${ch>=0?'var(--g2)':'var(--r2)'}"></div></div></div><div style="text-align:right"><div class="cr-val">$${pFmt}</div><div class="cr-ch ${cls}">${ch>=0?'▲':'▼'}${Math.abs(ch).toFixed(2)}%</div></div></div>`;
  });
  w.innerHTML=h;
}
function renderCryptoHM(d,el){
  if(!el||!d)return;
  el.innerHTML=Object.keys(d).slice(0,8).map(id=>{
    const c=d[id];const m=CMETA[id]||{sym:id.toUpperCase()};
    const ch=c.usd_24h_change||0;
