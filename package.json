<script>
// ════════════════════════════════════════════════════════════
// CONFIG — đổi BASE_URL sau khi deploy lên Vercel
// ════════════════════════════════════════════════════════════
const BASE_URL = ''; // '' = same origin khi deploy, hoặc 'https://your-app.vercel.app'
const API = (type, extra='') => `${BASE_URL}/api/data?type=${type}${extra}`;

// ════════════════════════════════════════════════════════════
// STATE
// ════════════════════════════════════════════════════════════
let AT = 0;
let cryptoData={}, commData={}, fxRates={}, indicesData={}, fearGreedData=null;
let chartHome=null, chartBTC=null, chartETH=null, chartMkt=null;
let uvMode = 'v4';
let selectedBank = null;

const BANKS = [
  {bin:'970436',name:'Vietcombank',short:'VCB',logo:'🏦'},
  {bin:'970418',name:'BIDV',short:'BIDV',logo:'🏛️'},
  {bin:'970405',name:'Agribank',short:'AGR',logo:'🌾'},
  {bin:'970415',name:'Vietinbank',short:'CTG',logo:'🏢'},
  {bin:'970432',name:'VPBank',short:'VPB',logo:'💼'},
  {bin:'970407',name:'Techcombank',short:'TCB',logo:'⚡'},
  {bin:'970422',name:'MB Bank',short:'MBB',logo:'💫'},
  {bin:'970423',name:'TPBank',short:'TPB',logo:'🔵'},
  {bin:'970416',name:'ACB',short:'ACB',logo:'🟢'},
  {bin:'970403',name:'Sacombank',short:'STB',logo:'🔴'},
  {bin:'970431',name:'Eximbank',short:'EIB',logo:'🌐'},
  {bin:'970454',name:'Tiên Phong',short:'TPF',logo:'🚀'},
];

const CHART_OPT = {
  plugins:{legend:{display:false},tooltip:{mode:'index',intersect:false,backgroundColor:'rgba(3,5,12,0.9)',titleColor:'#5a7090',bodyColor:'#dde6f0',borderColor:'rgba(0,168,255,0.18)',borderWidth:1}},
  scales:{
    x:{grid:{color:'rgba(255,255,255,0.03)'},ticks:{color:'#1d2e42',font:{size:9,family:'DM Mono'}}},
    y:{grid:{color:'rgba(255,255,255,0.03)'},ticks:{color:'#1d2e42',font:{size:9,family:'DM Mono'}}},
  },
  responsive:true,maintainAspectRatio:false,animation:{duration:500},
  interaction:{mode:'index',intersect:false},
};

// ════════════════════════════════════════════════════════════
// UTILS
// ════════════════════════════════════════════════════════════
function $(id){return document.getElementById(id);}
function setE(id,v){const el=$(id);if(el)el.textContent=v;}
function ri(a,b){return Math.floor(Math.random()*(b-a+1))+a;}
function fmtB(n){if(!n)return'—';if(n>=1e12)return'$'+(n/1e12).toFixed(2)+'T';if(n>=1e9)return'$'+(n/1e9).toFixed(2)+'B';if(n>=1e6)return'$'+(n/1e6).toFixed(2)+'M';return'$'+n.toLocaleString();}
function escH(s){return s?.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')||'';}
function now2(){return new Date().toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit'});}
function spin(id){$(id)?.classList.add('spinning');}
function toast(msg,dur=2500){const t=$('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),dur);}
function cp(id,btn){navigator.clipboard.writeText($(id).textContent).then(()=>{btn.textContent='✓ Đã sao chép';btn.classList.add('ok');setTimeout(()=>{btn.textContent='Sao chép';btn.classList.remove('ok');},1800);});}

function setChip(id,pct){
  const el=$(id); if(!el)return;
  const v=parseFloat(pct)||0;
  el.className='sc-ch '+(v>=0?'u':'d');
  el.textContent=(v>=0?'▲':'▼')+Math.abs(v).toFixed(2)+'%';
}

async function apiFetch(type,extra=''){
  try{
    const r=await fetch(API(type,extra),{signal:AbortSignal.timeout(20000)});
    if(!r.ok) return null;
    const d=await r.json();
    return d.ok ? d.data : null;
  }catch(e){console.warn('API fetch error:',type,e);return null;}
}

// ════════════════════════════════════════════════════════════
// NAVIGATION
// ════════════════════════════════════════════════════════════
function go(n){
  document.querySelectorAll('.pg').forEach((el,i)=>el.classList.toggle('on',i===n));
  document.querySelectorAll('.tb').forEach((el,i)=>el.classList.toggle('on',i===n));
  document.querySelectorAll('.nb').forEach((el,i)=>el.classList.toggle('on',i===n));
  AT=n;
  if(n===1) loadMarketPage();
  if(n===2) loadCryptoPage();
  if(n===3) loadWeatherPage();
  if(n===4) loadNews();
  if(n===5) loadWorldPage();
  if(n===6) loadVNPage();
}
function swTK(id,btn){
  ['dancu','qr','bank','tools','batch'].forEach(t=>{
    const el=$('tkp-'+t); if(el)el.classList.toggle('on',t===id);
  });
  document.querySelectorAll('.tk-tab').forEach(b=>b.classList.remove('act'));
  btn.classList.add('act');
  if(id==='bank') initBankGrid();
}

// ════════════════════════════════════════════════════════════
// CLOCK
// ════════════════════════════════════════════════════════════
function updateClock(){
  const el=$('clkEl');
  if(el) el.textContent=new Date().toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false});
}

const WCITIES=[
  {name:'New York',tz:'America/New_York'},{name:'London',tz:'Europe/London'},
  {name:'Frankfurt',tz:'Europe/Berlin'},{name:'Dubai',tz:'Asia/Dubai'},
  {name:'Mumbai',tz:'Asia/Kolkata'},{name:'Hà Nội',tz:'Asia/Ho_Chi_Minh'},
  {name:'Singapore',tz:'Asia/Singapore'},{name:'Tokyo',tz:'Asia/Tokyo'},
  {name:'Sydney',tz:'Australia/Sydney'},
];
function mktOpen(tz){
  const n=new Date(),l=new Date(n.toLocaleString('en-US',{timeZone:tz}));
  const h=l.getHours(),m=l.getMinutes(),dw=l.getDay();
  if(dw===0||dw===6)return false;
  const mins=h*60+m;
  if(tz.includes('New_York'))return mins>=570&&mins<960;
  if(tz.includes('London')||tz.includes('Berlin'))return mins>=480&&mins<1020;
  if(tz.includes('Tokyo'))return (mins>=540&&mins<720)||(mins>=750&&mins<900);
  if(tz.includes('Ho_Chi_Minh'))return (mins>=555&&mins<720)||(mins>=780&&mins<900);
  if(tz.includes('Singapore'))return mins>=540&&mins<1020;
  return mins>=540&&mins<960;
}
function refreshClocks(){
  const el=$('worldClocks'); if(!el)return;
  const now=new Date();
  el.innerHTML=WCITIES.map(c=>{
    const t=now.toLocaleTimeString('vi-VN',{hour:'2-digit',minute:'2-digit',timeZone:c.tz,hour12:false});
    const d=now.toLocaleDateString('vi-VN',{weekday:'short',timeZone:c.tz});
    const op=mktOpen(c.tz);
    return `<div class="clk-cell${op?' mopen':''}"><div><span class="cdot${op?' open':''}"></span></div><div class="cty">${c.name}</div><div class="ctm">${t}</div><div class="cdt">${d}</div></div>`;
  }).join('');
}

// ════════════════════════════════════════════════════════════
// TICKER
// ════════════════════════════════════════════════════════════
function buildTicker(){
  const items=[];
  if(cryptoData.coins){
    const d=cryptoData.coins;
    const CM={bitcoin:{s:'BTC'},ethereum:{s:'ETH'},solana:{s:'SOL'},binancecoin:{s:'BNB'},ripple:{s:'XRP'},dogecoin:{s:'DOGE'}};
    Object.entries(CM).forEach(([id,m])=>{
      if(!d[id])return;
      const p=d[id].usd,ch=d[id].usd_24h_change||0,cls=ch>=0?'u':'d';
      const pf=p>1?'$'+p.toLocaleString('en-US',{maximumFractionDigits:2}):'$'+p.toFixed(4);
      items.push(`<span class="tki"><span class="s">${m.s}</span>${pf}<span class="${cls}">${ch>=0?'▲':'▼'}${Math.abs(ch).toFixed(2)}%</span></span>`);
    });
  }
  if(fxRates?.rates){
    const r=fxRates.rates;
    if(r.VND) items.push(`<span class="tki"><span class="s">USD/VND</span>${Math.round(r.VND).toLocaleString('vi-VN')}</span>`);
    if(r.EUR) items.push(`<span class="tki"><span class="s">EUR/USD</span>${(1/r.EUR).toFixed(4)}</span>`);
    if(r.JPY) items.push(`<span class="tki"><span class="s">USD/JPY</span>${r.JPY.toFixed(2)}</span>`);
    if(r.CNY) items.push(`<span class="tki"><span class="s">USD/CNY</span>${r.CNY.toFixed(4)}</span>`);
  }
  if(commData.gold) items.push(`<span class="tki"><span class="s">XAU/USD</span>$${commData.gold.price?.toFixed(2)||'—'}<span class="${(commData.gold.change||0)>=0?'u':'d'}">${(commData.gold.change||0)>=0?'▲':'▼'}${Math.abs(commData.gold.change||0).toFixed(2)}%</span></span>`);
  if(commData.brent) items.push(`<span class="tki"><span class="s">BRENT</span>$${commData.brent.price?.toFixed(2)||'—'}</span>`);
  if(!items.length) return;
  const content=items.join('<span class="tki sep">·</span>');
  $('tkEl').innerHTML=content+content;
}

// ════════════════════════════════════════════════════════════
// HOME PAGE DATA LOAD
// ════════════════════════════════════════════════════════════
async function loadHome(){
  const [cData, fData, fgData, commRaw] = await Promise.all([
    apiFetch('crypto'), apiFetch('forex'), apiFetch('feargreed'), apiFetch('commodities')
  ]);

  if(cData){
    cryptoData=cData;
    const d=cData.coins;
    if(d?.bitcoin){setE('h-btc','$'+Math.round(d.bitcoin.usd).toLocaleString());setChip('h-btc-ch',d.bitcoin.usd_24h_change);}
    if(d?.ethereum){setE('h-eth','$'+d.ethereum.usd.toLocaleString('en-US',{maximumFractionDigits:2}));setChip('h-eth-ch',d.ethereum.usd_24h_change);}
    renderCryptoHM(d,$('hmapCrypto'));
    setE('cr-mktcap',fmtB(cData.totalMarketCap));
    setE('cr-btcdom',(cData.btcDominance||0).toFixed(1)+'%');
    setE('cr-vol',fmtB(cData.totalVolume));
    setE('cr-count',(cData.activeCryptos||0).toLocaleString());
  }
  if(fData){
    fxRates=fData;
    const vnd=fData.rates.VND;
    if(vnd){setE('h-usdvnd',Math.round(vnd).toLocaleString('vi-VN'));}
    setChip('h-usdvnd-ch',0);
  }
  if(fgData){
    fearGreedData=fgData;
    const val=fgData.current.value;
    setE('h-fg',val);setE('h-fgtxt',fgLabel(fgData.current.label));
    setE('fgNum',val);setE('fgTxt',fgLabel(fgData.current.label));
    const color=val<25?'var(--r2)':val<45?'var(--amber)':val<55?'var(--amber2)':val<75?'var(--g)':'var(--g2)';
    const fgN=$('fgNum');if(fgN)fgN.style.color=color;
    const nd=$('fgNeedle');if(nd)nd.style.left=val+'%';
    const ts=new Date(parseInt(fgData.current.timestamp)*1000).toLocaleDateString('vi-VN');
    setE('fgDate','Cập nhật: '+ts);
    renderFGHist(fgData.history);
  }
  if(commRaw){
    commData=commRaw;
    if(commRaw.gold){setE('h-gold','$'+(commRaw.gold.price||0).toLocaleString('en-US',{maximumFractionDigits:2}));setChip('h-gold-ch',commRaw.gold.change||0);}
    if(commRaw.brent){setE('h-oil','$'+(commRaw.brent.price||0).toFixed(2));setChip('h-oil-ch',commRaw.brent.change||0);}
    renderCommHM($('hmapComm'));
  }
  buildTicker();
  setTimeout(drawHomeChart,300);
}

function fgLabel(t){return{'Extreme Fear':'😱 Cực Sợ Hãi','Fear':'😨 Sợ Hãi','Neutral':'😐 Trung Lập','Greed':'😏 Tham Lam','Extreme Greed':'🤑 Cực Tham Lam'}[t]||t;}

function renderFGHist(history){
  const el=$('fgHist'); if(!el||!history) return;
  const days=['CN','T2','T3','T4','T5','T6','T7'];
  el.innerHTML=history.slice(0,7).reverse().map(h=>{
    const v=h.value;
    const color=v<25?'#ff3b4e':v<45?'#ffb020':v<55?'#ffd060':v<75?'#00c97a':'#00a8ff';
    const hPx=Math.max(20,Math.round(v*0.6));
    const d=new Date(parseInt(h.timestamp)*1000);
    const lbl=days[d.getDay()];
    return `<div class="fg-hbar"><div class="fg-hv" style="color:${color}">${v}</div><div class="fg-hb" style="height:${hPx}px;background:${color}20;border-top:2px solid ${color};"></div><div class="fg-hd">${lbl}</div></div>`;
  }).join('');
}

